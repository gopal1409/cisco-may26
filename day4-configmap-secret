apiVersion: v1

kind: Secret
metadata:
  name: mysql-secret
type: Opaque #currently k8s support only base64 encoded string as secret data, so we need to specify the type as Opaque
data: #we need to provide the secret in key value format
  mysecret: ZGJwYXNzd29yZDEwMQ==

