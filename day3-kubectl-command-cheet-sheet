kubectl describe rolebinding <binding-name>  # Get role binding details
kubectl create role <role> --verb=get,list --resource=pods  # Create role
kubectl create rolebinding <binding> --role=<role> --serviceaccount=<sa>
kubectl auth can-i get pods --as=system:serviceaccount:default:user1
kubectl auth reconcile -f <rbac.yaml>        # Apply RBAC policies
```

