#-------------------------------------
#stage1: build the application
#------------------------------------
FROM maven:3.9.16-eclipse-temurin-8-noble AS build
#set the working directory inside the container
#copying the maven project descripto and source file
WORKDIR /app
COPY pom.xml .
COPY src ./src
#lets package the application into a jar file
RUN mvn clean package -DskipTest

#---------------------
#Stage2: create the fimal production image
#-------------------------------------
FROM maven:3.9.16-eclipse-temurin-8-noble

#set the working directory
WORKDIR /app
#from the build stage we are geeting the jar using copy command
COPY --from=build /app/target/*.jar app.jar
EXPOSE 8080
ENTRYPOINT ["java","-jar","app.jar"]

