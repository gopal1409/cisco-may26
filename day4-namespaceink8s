kind: Pod
metadata:
  name: p1
  namespace: dev
spec:
  containers:
  - name: myapp
    image: nginx
    resources:
      limits:
        memory: "800Mi"
        cpu: "800m"
      requests:
        memory: "600Mi"
        cpu: "400m"
   
