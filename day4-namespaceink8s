  ############lets create quota in namespace
    103  vi quota.yml
apiVersion: v1
kind: ResourceQuota
metadata:
  name: quota-for-dev
  namespace: dev
spec:
  hard:
    pods: "10" #this is the maximum number of pods that can be created in the namespace
    requests.cpu: "1" #this is the maximum amount of cpu that can be requested by the pods in the namespace
    requests.memory: 1Gi #this is the maximum amount of memory that can be requested by the pods in the namespace
    limits.cpu: "2" #this is the maximum amount of cpu that can be limited by the pods in the namespace
    limits.memory: 2Gi #this is the maximum amount of memory that can be limited by the pods in the namespace
    #requests memomry it means that if i create a pod with container inside it 
    ###this give the gurantee that allocated memory will be available for the container to run and if the container is not able to get the requested memory then
  104  kubectl apply -f quota.yml
      #this will not show the quota as it is looking into default namespace
  105  kubectl get resourcequota
      #when we use -n with the namespace it will show
  106  kubectl -n dev get resourcequota
  107  kubectl -n dev describe resourcequota

